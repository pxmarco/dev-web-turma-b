a bebida</label>\r\n\r\n        <div class=\"checkbox-container\">\r\n          <input type=\"checkbox\" />\r\n          <span>Coca</span>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"inputs\">\r\n        <input\r\n          type=\"submit\"\r\n          class=\"submit-btn\"\r\n          value=\"Confirmar pedido\"\r\n        />\r\n      </div>\r\n\r\n    </form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PedidoComponent\",\r\n\r\n  props: {\r\n    burguer: null,\r\n  },\r\n\r\n  data() {\r\n    return {\r\n      listaPontosCarne: [],\r\n    };\r\n  },\r\n\r\n  methods: {\r\n    async getTiposPontos() {\r\n      const response = await fetch(\r\n        \"http://localhost:3000/tipos_pontos\"\r\n      );\r\n\r\n      const dados = await response.json();\r\n\r\n      this.listaPontosCarne = dados;\r\n    },\r\n  },\r\n\r\n  mounted() {\r\n    this.getTiposPontos();\r\n  },\r\n};\r\n</script>\r\n\r\n<style></style>"],"mappings":"AA+DA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EAEvBC,KAAK,EAAE;IACLC,OAAO,EAAE;EACX,CAAC;EAEDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,gBAAgB,EAAE;IACpB,CAAC;EACH,CAAC;EAEDC,OAAO,EAAE;IACP,MAAMC,cAAcA,CAAA,EAAG;MACrB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAC1B,oCACF,CAAC;MAED,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MAEnC,IAAI,CAACN,gBAAe,GAAIK,KAAK;IAC/B;EACF,CAAC;EAEDE,OAAOA,CAAA,EAAG;IACR,IAAI,CAACL,cAAc,CAAC,CAAC;EACvB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}