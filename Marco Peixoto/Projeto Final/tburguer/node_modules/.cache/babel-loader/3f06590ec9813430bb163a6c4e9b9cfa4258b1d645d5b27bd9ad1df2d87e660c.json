{"ast":null,"code":"export default {\n  name: \"ListaPedidoComponent\",\n  data() {\n    return {\n      listaPedidosRealizados: [],\n      listaStatusPedido: []\n    };\n  },\n  methods: {\n    async consultarPedidos() {\n      const response = await fetch(\"http://localhost:3000/pedidos\");\n      this.listaPedidosRealizados = await response.json();\n    },\n    async consultarStatusPedido() {\n      const response = await fetch(\"http://localhost:3000/status_pedido\");\n      this.listaStatusPedido = await response.json();\n    },\n    async atualizarStatusPedido(event, idPedido) {\n      const idPedidoAtualizado = event.target.value;\n      const atualizacaoJson = JSON.stringify({\n        statusId: idPedidoAtualizado\n      });\n      await fetch(`http://localhost:3000/pedidos/${idPedido}`, {\n        method: \"PATCH\",\n        headers: {\n          \"Content-type\": \"application/json\"\n        },\n        body: atualizacaoJson\n      });\n      //fazer algo ápos alterar\n    },\n    async deletarPedido(event, idPedido) {\n      const response = await fetch(`http://localhost:3000/pedidos/${idPedido}`, {\n        method: \"DELETE\"\n      });\n      await this.consultarPedidos();\n    }\n  },\n  mounted() {\n    this.consultarPedidos();\n    this.consultarStatusPedido();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidosRealizados","listaStatusPedido","methods","consultarPedidos","response","fetch","json","consultarStatusPedido","atualizarStatusPedido","event","idPedido","idPedidoAtualizado","target","value","atualizacaoJson","JSON","stringify","statusId","method","headers","body","deletarPedido","mounted"],"sources":["C:\\Users\\marcoamp\\Desktop\\Git Hub\\dev-web-turma-b\\Marco Peixoto\\Projeto Final\\tburguer\\src\\components\\ListaPedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div id=\"pedidos-tabela\">\r\n      <div>\r\n        <div id=\"pedidos-tabela-cabecalho\">\r\n          <div id=\"ordem-id\">#ID</div>\r\n          <div>Nome</div>\r\n          <div>Hamburguer</div>\r\n          <div>Ponto</div>\r\n          <div>opcionais</div>\r\n          <div>Status</div>\r\n          <div id=\"div-acoes\">Ações</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div\r\n      class=\"pedidos-tabela-linha\"\r\n      v-for=\"pedido in listaPedidosRealizados\"\r\n      :key=\"pedido.id\"\r\n    >\r\n      <div id=\"ordem-numero\">{{ pedido.id }}</div>\r\n      <div>{{ pedido.nome }}</div>\r\n      <div>{{ pedido.burguer.nome }}</div>\r\n      <div>{{ pedido.ponto.descricao }}</div>\r\n      <div>\r\n        <ul>\r\n          <li v-for=\"(complemento, index) in pedido.complemento\" :key=\"index\">\r\n            {{ complemento.nome }}\r\n          </li>\r\n        </ul>\r\n        <div class=\"divider\"></div>\r\n        <ul>\r\n          <li v-for=\"(refri, index) in pedido.bebidas\" :key=\"index\">\r\n            {{ refri.nome }}\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div>\r\n        <select\r\n          @change=\"atualizarStatusPedido($event, pedido.id)\"\r\n          name=\"status\"\r\n          class=\"status\"\r\n        >\r\n          <option value=\"\">Selecione</option>\r\n          <option\r\n            v-for=\"status in listaStatusPedido\"\r\n            :key=\"status.id\"\r\n            :value=\"status.id\"\r\n            :selected=\"status.id == pedido.statusId\"\r\n          >\r\n            {{ status.descricao }}\r\n          </option>\r\n        </select>\r\n      </div>\r\n      <div id=\"div-acoes\">\r\n        <img \r\n          src=\"/img/icone_lixeira.png\" \r\n          width=\"35px\" \r\n          height=\"35px\"\r\n          @click=\"deletarPedido($event, pedido.id)\"\r\n          style=\"cursor: pointer;\"\r\n        />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"ListaPedidoComponent\",\r\n  data() {\r\n    return {\r\n      listaPedidosRealizados: [],\r\n      listaStatusPedido: [],\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarPedidos() {\r\n      const response = await fetch(\"http://localhost:3000/pedidos\");\r\n      this.listaPedidosRealizados = await response.json();\r\n    },\r\n    async consultarStatusPedido() {\r\n      const response = await fetch(\"http://localhost:3000/status_pedido\");\r\n      this.listaStatusPedido = await response.json();\r\n    },\r\n    async atualizarStatusPedido(event, idPedido) {\r\n      const idPedidoAtualizado = event.target.value;\r\n      const atualizacaoJson = JSON.stringify({ statusId: idPedidoAtualizado });\r\n      await fetch(`http://localhost:3000/pedidos/${idPedido}`, {\r\n        method: \"PATCH\",\r\n        headers: { \"Content-type\": \"application/json\" },\r\n        body: atualizacaoJson,\r\n      });\r\n      //fazer algo ápos alterar\r\n    },\r\n    async deletarPedido(event, idPedido) {\r\n      const response = await fetch(`http://localhost:3000/pedidos/${idPedido}`, {\r\n        method: \"DELETE\",\r\n      });\r\n      await this.consultarPedidos();\r\n    },\r\n  },\r\n  mounted() {\r\n    this.consultarPedidos();\r\n    this.consultarStatusPedido();\r\n  },\r\n};\r\n</script>\r\n<style scoped>\r\n#pedidos-tabela {\r\n  width: 100%;\r\n  margin: 0 auto;\r\n}\r\n\r\n#pedidos-tabela-cabecalho,\r\n#pedidos-tabela-linhas,\r\n.pedidos-tabela-linha {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n#pedidos-tabela-cabecalho {\r\n  font-weight: bold;\r\n  padding: 12px;\r\n  border-bottom: 2px solid #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho div,\r\n.pedidos-tabela-linha div {\r\n  width: 18%;\r\n}\r\n\r\n.pedidos-tabela-linha {\r\n  width: 100%;\r\n  padding: 12px;\r\n  border-bottom: 1px dotted #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho #ordem-id,\r\n.pedidos-tabela-linha #ordem-numero,\r\n.pedidos-tabela-linha #div-acoes,\r\n#pedidos-tabela-cabecalho #div-acoes {\r\n  width: 5%;\r\n}\r\n</style>\r\n"],"mappings":"AAoEA,eAAe;EACbA,IAAI,EAAE,sBAAsB;EAC5