{"ast":null,"code":"export default {\n  name: \"ListaPedidoComponent\",\n  data() {\n    return {\n      listaPedidosRealizados: []\n    };\n  },\n  methods: {\n    async consultarPedidos() {\n      const response = await fetch(\"http://localhost:3000/pedidos\");\n      this.listaPedidosRealizados = await response.json();\n    },\n    async consultarStatusPedido() {\n      const response = await fetch(\"http://localhost:3000/status_pedidos\");\n      this.listaStatusPedidos = await response.json();\n    },\n    async atualizarStatusPedido(event, idPedido) {\n      const statusId = event.target.value;\n      const atualizacaoJson = JSON.stringify({\n        statusId: idPedidoAtualizado\n      });\n      await fetch(`http://localhost:3000/pedidos/${idPedido}`, {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json'\n        },\n        body: atualizacaoJson\n      });\n    }\n  },\n  mounted() {\n    this.consultarPedidos();\n    this.consultarStatusPedido();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidosRealizados","methods","consultarPedidos","response","fetch","json","consultarStatusPedido","listaStatusPedidos","atualizarStatusPedido","event","idPedido","statusId","target","value","atualizacaoJson","JSON","stringify","idPedidoAtualizado","method","headers","body","mounted"],"sources":["C:\\Users\\marcoamp\\Desktop\\Git Hub\\dev-web-turma-b\\Marco Peixoto\\Projeto Final\\tburguer\\src\\components\\ListaPedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div id=\"pedidos-tabela\">\r\n      <div>\r\n        <div id=\"pedidos-tabela-cabecalho\">\r\n          <div id=\"ordem-id\">#ID</div>\r\n          <div>Nome</div>\r\n          <div>Hamburguer</div>\r\n          <div>Ponto</div>\r\n          <div>opcionais</div>\r\n          <div>Status</div>\r\n          <div id=\"div-acoes\">Ações</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div\r\n      class=\"pedidos-tabela-linha\"\r\n      v-for=\"pedido in listaPedidosRealizados\"\r\n      :key=\"pedido.id\"\r\n    >\r\n      <div id=\"ordem-numero\">{{ pedido.id }}</div>\r\n      <div>{{ pedido.nome || '-' }}</div>\r\n      <div>{{ (pedido.hamburguer && pedido.hamburguer.nome) || '-' }}</div>\r\n      <div>{{ (pedido.ponto && pedido.ponto.descricao) || pedido.ponto || '-' }}</div>\r\n      <div>\r\n        <ul>\r\n          <li v-for=\"(complemento, index) in (pedido.complemento || [])\" :key=\"index\">\r\n            {{ complemento.nome || '-' }}\r\n          </li>\r\n        </ul>\r\n        <div class=\"divider\"></div>\r\n        <ul>\r\n          <li v-for=\"(refri, index) in (pedido.bebidas || [])\" :key=\"index\">\r\n            {{ refri.nome || '-' }}\r\n          </li>\r\n        </ul>\r\n      </div>\r\n      <div>\r\n        <select @change=\"atualizarStatusPedido($event, pedido.id)\" name=\"status\" class=\"status\">\r\n            <option value=\"\">Selecione</option>\r\n            <option v-for=\"status in listaStatusPedidos\" :key=\"status.id\" :value=\"status.id\"\r\n            :selected=\"status.id == pedido.statusId\"\r\n            >\r\n              {{ status.descricao }}\r\n            </option>\r\n        </select>\r\n      </div>\r\n      <div id=\"div-acoes\">\r\n        <img src=\"/img/icone_lixeira.png\" width=\"35px\" height=\"35px\" />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"ListaPedidoComponent\",\r\n  data() {\r\n    return {\r\n      listaPedidosRealizados: [],\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarPedidos() {\r\n      const response = await fetch(\"http://localhost:3000/pedidos\");\r\n      this.listaPedidosRealizados = await response.json();\r\n    },\r\n    async consultarStatusPedido() {\r\n        const response = await fetch(\"http://localhost:3000/status_pedidos\");\r\n        this.listaStatusPedidos = await response.json();\r\n    },\r\n    async atualizarStatusPedido (event, idPedido) {\r\n        const statusId = event.target.value;\r\n        const atualizacaoJson = JSON.stringify({ statusId: idPedidoAtualizado });\r\n        await fetch(`http://localhost:3000/pedidos/${idPedido}`, {\r\n            method: 'PATCH',\r\n            headers: {'Content-Type': 'application/json'},\r\n            body: atualizacaoJson,\r\n        });\r\n    },\r\n  },\r\n  mounted() {\r\n    this.consultarPedidos();\r\n    this.consultarStatusPedido();\r\n  },\r\n};\r\n</script>\r\n<style scoped>\r\n#pedidos-tabela {\r\n  width: 100%;\r\n  margin: 0 auto;\r\n}\r\n\r\n#pedidos-tabela-cabecalho,\r\n#pedidos-tabela-linhas,\r\n.pedidos-tabela-linha {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n#pedidos-tabela-cabecalho {\r\n  font-weight: bold;\r\n  padding: 12px;\r\n  border-bottom: 2px solid #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho div,\r\n.pedidos-tabela-linha div {\r\n  width: 18%;\r\n}\r\n\r\n.pedidos-tabela-linha {\r\n  width: 100%;\r\n  padding: 12px;\r\n  border-bottom: 1px dotted #222;\r\n}\r\n\r\n#pedidos-tabela-cabecalho #ordem-id,\r\n.pedidos-tabela-linha #ordem-numero,\r\n.pedidos-tabela-linha #div-acoes,\r\n#pedidos-tabela-cabecalho #div-acoes {\r\n  width: 5%;\r\n}\r\n</style>\r\n"],"mappings":"AAuDA,eAAe;EACbA,IAAI,EAAE,sBAAsB;EAC5BC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,sBAAsB,EAAE;IAC1B,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,gBAAgBA,CAAA,EAAG;MACvB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,+BAA+B,CAAC;MAC7D,IAAI,CAACJ,sBAAqB,GAAI,MAAMG,QAAQ,CAACE,IAAI,CAAC,CAAC;IACrD,CAAC;IACD,MAAMC,qBAAqBA,CAAA,EAAG;MAC1B,MAAMH,QAAO,GAAI,MAAMC,KAAK,CAAC,sCAAsC,CAAC;MACpE,IAAI,CAACG,kBAAiB,GAAI,MAAMJ,QAAQ,CAACE,IAAI,CAAC,CAAC;IACnD,CAAC;IACD,MAAMG,qBAAoBA,CAAGC,KAAK,EAAEC,QAAQ,EAAE;MAC1C,MAAMC,QAAO,GAAIF,KAAK,CAACG,MAAM,CAACC,KAAK;MACnC,MAAMC,eAAc,GAAIC,IAAI,CAACC,SAAS,CAAC;QAAEL,QAAQ,EAAEM;MAAmB,CAAC,CAAC;MACxE,MAAMb,KAAK,CAAC,iCAAiCM,QAAQ,EAAE,EAAE;QACrDQ,MAAM,EAAE,OAAO;QACfC,OAAO,EAAE;UAAC,cAAc,EAAE;QAAkB,CAAC;QAC7CC,IAAI,EAAEN;MACV,CAAC,CAAC;IACN;EACF,