{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontosCarne: [],\n      listaComplementos: [],\n      listaBebidas: []\n    };\n  },\n  methods: {\n    async getTiposPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await response.json();\n      this.listaPontosCarne = dados;\n    },\n    async getOpcionais() {\n      const response = await fetch(\"http://localhost:3000/opcionais\");\n      const dados = await response.json();\n      this.listaComplementos = dados.complemento;\n      this.listaBebidas = dados.bebidas;\n    }\n  },\n  mounted() {\n    this.getTiposPontos();\n    this.getOpcionais();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontosCarne","listaComplementos","listaBebidas","methods","getTiposPontos","response","fetch","dados","json","getOpcionais","complemento","bebidas","mounted"],"sources":["C:\\Users\\marcoamp\\Desktop\\Git Hub\\dev-web-turma-b\\Marco Peixoto\\Projeto Final\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <form id=\"pedido-form\">\r\n      \r\n      <div>\r\n        <p id=\"nome-hamburguer-content\">\r\n          {{ burguer && burguer.nome ? burguer.nome : \"--\" }}\r\n        </p>\r\n\r\n        <img\r\n          id=\"foto-content\"\r\n          :src=\"burguer && burguer.foto ? burguer.foto : ''\"\r\n        />\r\n      </div>\r\n\r\n      <div class=\"inputs\" id=\"form-pedido\">\r\n        <label>Nome</label>\r\n        <input\r\n          type=\"text\"\r\n          placeholder=\"Digite seu Nome\"\r\n          id=\"nome-cliente\"\r\n        />\r\n      </div>\r\n\r\n      <div class=\"inputs\">\r\n        <label>Ponto da carne</label>\r\n\r\n        <select name=\"ponto-carne\" id=\"ponto-carne\">\r\n          <option value=\"\" selected>Selecione o ponto</option>\r\n          <option v-for=\"pontoCarne in listaPontosCarne\"\r\n          :key=\"pontoCarne.id\"\r\n          :value=\"pontoCarne\">{{ pontoCarne.descricao }}</option>\r\n        </select>\r\n      </div>\r\n\r\n      <div>\r\n        <label id=\"opcionais-titulo\">Selecionar os opcionais</label>\r\n        <label id=\"opcionais-subtitulo\">Selecionar os complementos</label>\r\n\r\n        <div v-for=\"complemento in listaComplementos\"\r\n        :key=\"complemento.id\" \r\n        class=\"checkbox-container\">\r\n          <input type=\"checkbox\" />\r\n          <span>Batata</span>\r\n        </div>\r\n\r\n        <label>Adicione uma bebida</label>\r\n\r\n        <div class=\"checkbox-container\">\r\n          <input type=\"checkbox\" />\r\n          <span>Coca</span>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"inputs\">\r\n        <input\r\n          type=\"submit\"\r\n          class=\"submit-btn\"\r\n          value=\"Confirmar pedido\"\r\n        />\r\n      </div>\r\n\r\n    </form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PedidoComponent\",\r\n\r\n  props: {\r\n    burguer: null,\r\n  },\r\n\r\n  data() {\r\n    return {\r\n      listaPontosCarne: [],\r\n      listaComplementos: [],\r\n      listaBebidas: [],\r\n    };\r\n  },\r\n\r\n  methods: {\r\n    async getTiposPontos() {\r\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n      const dados = await response.json();\r\n      this.listaPontosCarne = dados;\r\n    },\r\n    async getOpcionais() {\r\n        const response = await fetch(\"http://localhost:3000/opcionais\");\r\n        const dados = await response.json();\r\n        this.listaComplementos = dados.complemento;\r\n        this.listaBebidas = dados.bebidas;\r\n    },\r\n  },\r\n  mounted() {\r\n    this.getTiposPontos();\r\n    this.getOpcionais();\r\n  },\r\n};\r\n</script>\r\n\r\n<style></style>"],"mappings":"AAmEA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EAEvBC,KAAK,EAAE;IACLC,OAAO,EAAE;EACX,CAAC;EAEDC,IA