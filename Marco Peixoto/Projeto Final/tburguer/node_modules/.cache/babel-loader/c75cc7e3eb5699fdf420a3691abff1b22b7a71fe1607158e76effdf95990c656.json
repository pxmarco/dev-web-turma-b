{"ast":null,"code":"export default {\n  name: \"ListaPedidoComponent\",\n  data() {\n    return {\n      listaPedidosRealizados: []\n    };\n  },\n  methods: {\n    async consultarPedidos() {\n      const response = await fetch(\"http://localhost:3000/pedidos\");\n      this.listaPedidosRealizados = await response.json();\n    }\n  },\n  mounted() {\n    this.consultarPedidos();\n  }\n};","map":{"version":3,"names":["name","data","listaPedidosRealizados","methods","consultarPedidos","response","fetch","json","mounted"],"sources":["C:\\Users\\marcoamp\\Desktop\\Git Hub\\dev-web-turma-b\\Marco Peixoto\\Projeto Final\\tburguer\\src\\components\\ListaPedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <div id=\"pedidos-tabela\">\r\n            <div>\r\n                <div id=\"pedidos-tabela-cabeçalho\">\r\n                    <div id=\"ordem-id\">#ID</div>\r\n                    <div>Nome</div>\r\n                    <div>Hmburguer</div>\r\n                    <div>Ponto</div>\r\n                    <div>Opcionais</div>\r\n                    <div>Status</div>\r\n                    <div id=\"div-acoes\">Ações</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <div\r\n        class=\"pedidos-tabela-linha\"\r\n        v-for=\"pedido in listaPedidosRealizados\"\r\n        :key=\"pedido.id\"\r\n    >\r\n        <div>{{ pedido.id }}</div>\r\n        <div>{{ pedido.nome || '-' }}</div>\r\n        <div>{{ (pedido.burguer && pedido.burguer.nome) || '-' }}</div>\r\n        <div>{{ (pedido.ponto && pedido.ponto.descricao) || pedido.ponto || '-' }}</div>\r\n        <div>\r\n            <ul>\r\n                <li v-for=\"(complemento, index) in (pedido.complemento || [])\" :key=\"index\">\r\n                    {{ complemento.nome || '-' }}\r\n                </li>\r\n            </ul>\r\n            <div class=\"divider\"></div>\r\n        </div>\r\n        <div>\r\n            <ul>\r\n                <li v-for=\"(bebida, index) in (pedido.bebidas || [])\" :key=\"index\">\r\n                    {{ bebida.nome || '-' }}\r\n                </li>\r\n            </ul>\r\n            <div class=\"divider\"></div>\r\n        </div>\r\n        <div>\r\n            <ul>\r\n                <li v-for=\"(opcionais, index) in (pedido.opcionais || [])\" :key=\"index\">\r\n                    {{ opcionais.nome || '-' }}\r\n                </li>\r\n            </ul>\r\n            <div class=\"divider\"></div>\r\n        </div>\r\n    </div>\r\n</template>\r\n<script>\r\nexport default {\r\n\r\n    name:\"ListaPedidoComponent\",\r\n    data() {\r\n        return {\r\n            listaPedidosRealizados: [],\r\n        };\r\n    },\r\n    methods: {\r\n        async consultarPedidos() {\r\n            const response = await fetch(\"http://localhost:3000/pedidos\");\r\n            this.listaPedidosRealizados = await response.json();\r\n        }\r\n    },\r\n    mounted() {\r\n        this.consultarPedidos();\r\n    },\r\n};\r\n</script>\r\n<style scoped></style>"],"mappings":"AAqDA,eAAe;EAEXA,IAAI,EAAC,sBAAsB;EAC3BC,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,sBAAsB,EAAE;IAC5B,CAAC;EACL,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,gBAAgBA,CAAA,EAAG;MACrB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,+BAA+B,CAAC;MAC7D,IAAI,CAACJ,sBAAqB,GAAI,MAAMG,QAAQ,CAACE,IAAI,CAAC,CAAC;IACvD;EACJ,CAAC;EACDC,OAAOA,CAAA,EAAG;IACN,IAAI,CAACJ,gBAAgB,CAAC,CAAC;EAC3B;AACJ,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}