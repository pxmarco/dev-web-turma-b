r\n          <input type=\"checkbox\" :name=\"bebidas.nome\" :value=\"bebidas\" v-model=\"ListaBebidaSelecionadas\"/>\r\n          <span>{{ bebidas.nome }}</span>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"inputs\">\r\n        <input\r\n          type=\"submit\"\r\n          class=\"submit-btn\"\r\n          value=\"Confirmar pedido\"\r\n        />\r\n      </div>\r\n\r\n    </form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"PedidoComponent\",\r\n\r\n  props: {\r\n    burguer: null,\r\n  },\r\n\r\n  data() {\r\n    return {\r\n      listaPontosCarne: [],\r\n      listaComplementos: [],\r\n      listaBebidas: [],\r\n      nomeClientes: \"\",\r\n      pontoCarneSelecionado: \"\",\r\n      listaCpmplementesSelecionados: [],\r\n      ListaBebidaSelecionadas: [],\r\n    };\r\n  },\r\n\r\n  methods: {\r\n    async getTiposPontos() {\r\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n      const dados = await response.json();\r\n      this.listaPontosCarne = dados;\r\n    },\r\n    async getOpcionais() {\r\n        const response = await fetch(\"http://localhost:3000/opcionais\");\r\n        const dados = await response.json();\r\n        this.listaComplementos = dados.complemento;\r\n        this.listaBebidas = dados.bebidas;\r\n    },\r\n    async criarPedido(e) {\r\n\r\n        const dadosPedido = {\r\n            nome: this.nomeClientes,\r\n            ponto: this.pontoCarneSelecionado,\r\n            bebidas: Array.from(this.ListaBebidaSelecionadas),\r\n            complemento: Array.from(this.listaCpmplementesSelecionados),\r\n            burguer: this.burguer,\r\n            statusId: 5,\r\n        };\r\n\r\n        console.log(dadosPedido);\r\n\r\n        const dadosJson = JSON.stringify(dadosPedido);\r\n\r\n        const req = await fetch(\"http://localhost:3000/pedidos\", {\r\n            method: \"POST\",\r\n            headers: {\"Content-Type\": \"application/json\" },\r\n            body: dadosJson,\r\n        });\r\n    },\r\n  },\r\n  mounted() {\r\n    this.getTiposPontos();\r\n    this.getOpcionais();\r\n    this.getOpcionais();\r\n  },\r\n};\r\n</script>\r\n\r\n<style></style>"],"mappings":"AAqEA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EAEvBC,KAAK,EAAE;IACLC,OAAO,EAAE;EACX,CAAC;EAEDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,gBAAgB,EAAE,EAAE;MACpBC,iBAAiB,EAAE,EAAE;MACrBC,YAAY,EAAE,EAAE;MAChBC,YAAY,EAAE,EAAE;MAChBC,qBAAqB,EAAE,EAAE;MACzBC,6BAA6B,EAAE,EAAE;MACjCC,uBAAuB,EAAE;IAC3B,CAAC;EACH,CAAC;EAEDC,OAAO,EAAE;IACP,MAAMC,cAAcA,CAAA,EAAG;MACrB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,oCAAoC,CAAC;MAClE,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACZ,gBAAe,GAAIW,KAAK;IAC/B,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACjB,MAAMJ,QAAO,GAAI,MAAMC,KAAK,CAAC,iCAAiC,CAAC;MAC/D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACX,iBAAgB,GAAIU,KAAK,CAACG,WAAW;MAC1C,IAAI,CAACZ,YAAW,GAAIS,KAAK,CAACI,OAAO;IACrC,CAAC;IACD,MAAMC,WAAWA,CAACC,CAAC,EAAE;MAEjB,MAAMC,WAAU,GAAI;QAChBC,IAAI,EAAE,IAAI,CAAChB,YAAY;QACvBiB,KAAK,EAAE,IAAI,CAAChB,qBAAqB;QACjCW,OAAO,EAAEM,KAAK,CAACC,IAAI,CAAC,IAAI,CAAChB,uBAAuB,CAAC;QACjDQ,WAAW,EAAEO,KAAK,CAACC,IAAI,CAAC,IAAI,CAACjB,6BAA6B,CAAC;QAC3DP,OAAO,EAAE,IAAI,CAACA,OAAO;QACrByB,QAAQ,EAAE;MACd,CAAC;MAEDC,OAAO,CAACC,GAAG,CAACP,WAAW,CAAC;MAExB,MAAMQ,SAAQ,GAAIC,IAAI,CAACC,SAAS,CAACV,WAAW,CAAC;MAE7C,MAAMW,GAAE,GAAI,MAAMnB,KAAK,CAAC,+BAA+B,EAAE;QACrDoB,MAAM,EAAE,MAAM;QACdC,OAAO,EAAE;UAAC,cAAc,EAAE;QAAmB,CAAC;QAC9CC,IAAI,EAAEN;MACV,CAAC,CAAC;IACN;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACzB,cAAc,CAAC,CAAC;IACrB,IAAI,CAACK,YAAY,CAAC,CAAC;IACnB,IAAI,CAACA,YAAY,CAAC,CAAC;EACrB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}